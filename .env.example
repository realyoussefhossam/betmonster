# BetMonster local development environment
# Copy this file to .env and fill in the values, or run ./scripts/init_env.sh to generate them.

# Better Auth (Next.js app)
BETTER_AUTH_SECRET=change-me-to-a-random-secret
BETTER_AUTH_URL=http://localhost:3000

# Next.js public API
NEXT_PUBLIC_GO_API_URL=http://localhost:8080
GO_API_URL=http://localhost:8080

# Gateway
GATEWAY_PORT=8080
# JWKS_URL defaults to http://localhost:3000/api/auth/jwks outside Docker.
# In Docker Compose the gateway service overrides it to http://app:3000/api/auth/jwks.
# JWKS_URL=http://localhost:3000/api/auth/jwks
WALLET_SERVICE_ADDR=localhost:50051
ADMIN_USER_IDS=
# Currency-chain pairs supported by BetMonster. Each pair must be registered and
# active in your xcash deployment. The gateway and wallet derive the currency
# and chain dropdowns from this list, and reject any unsupported pair.
#
# Default list: EVM and Tron assets that xcash can process. Add anvil:* pairs
# for local testing with ./scripts/setup-xcash.sh. Remove anvil:* in production.
SUPPORTED_PAIRS=USDT:anvil,USDT:ethereum,USDT:bsc,USDT:polygon,USDT:tron,USDC:anvil,USDC:ethereum,USDC:bsc,USDC:polygon,USDC:base,USDC:arbitrum-one,ETH:anvil,ETH:ethereum,ETH:bsc,ETH:base,BNB:bsc,TRX:tron,POL:ethereum,POL:polygon,DAI:ethereum,SHIB:ethereum,BUSD:bsc

# SUPPORTED_CURRENCIES and SUPPORTED_CHAINS are automatically derived from
# SUPPORTED_PAIRS. Set them explicitly only if you need to override the derived
# lists (e.g., hide a currency from the UI without removing its pair).
#SUPPORTED_CURRENCIES=USDT,USDC,ETH,BNB,TRX,POL,DAI,SHIB,BUSD
#SUPPORTED_CHAINS=anvil,ethereum,bsc,polygon,tron,base,arbitrum-one
RATE_LIMIT_RPS=100
RATE_LIMIT_BURST=100
RATE_LIMIT_BACKEND=memory
REDIS_ADDR=redis:6379

# Deposit/withdrawal limits (empty string = no limit for that bound)
MIN_DEPOSIT=5
MAX_DEPOSIT=10000
DAILY_DEPOSIT=
MIN_WITHDRAWAL=10
MAX_WITHDRAWAL=5000
DAILY_WITHDRAWAL=

# Wallet
WALLET_PORT=8081
DATABASE_URL=postgres://wallet:wallet@localhost:5433/wallet?sslmode=disable
REDIS_ADDR=localhost:6379
NATS_URL=nats://localhost:4222

# xcash (self-hosted deposit gateway)
XCASH_BASE_URL=http://localhost:6688
XCASH_APPID=
XCASH_HMAC_KEY=
XCASH_WEBHOOK_SECRET=

# Postgres (used by Docker Compose)
POSTGRES_USER=wallet
POSTGRES_PASSWORD=wallet
POSTGRES_DB=wallet

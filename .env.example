# BetMonster local development environment
# Copy this file to .env and fill in the values, or run ./scripts/init_env.sh to generate them.

# Better Auth (Next.js app)
BETTER_AUTH_SECRET=change-me-to-a-random-secret
BETTER_AUTH_URL=http://localhost:3000

# Next.js public API
NEXT_PUBLIC_GO_API_URL=http://localhost:8080
GO_API_URL=http://localhost:8080

# Gateway
GATEWAY_PORT=8080
# JWKS_URL defaults to http://localhost:3000/api/auth/jwks outside Docker.
# In Docker Compose the gateway service overrides it to http://app:3000/api/auth/jwks.
# JWKS_URL=http://localhost:3000/api/auth/jwks
WALLET_SERVICE_ADDR=localhost:50051
ADMIN_USER_IDS=
SUPPORTED_CURRENCIES=USDT,USDC
# xcash supports EVM chains (anvil, base, ethereum, bsc) and Tron.
# Use comma-separated chain codes recognized by your xcash deployment.
SUPPORTED_CHAINS=anvil
RATE_LIMIT_RPS=100
RATE_LIMIT_BURST=100
RATE_LIMIT_BACKEND=memory
REDIS_ADDR=redis:6379

# Deposit/withdrawal limits (empty string = no limit for that bound)
MIN_DEPOSIT=5
MAX_DEPOSIT=10000
DAILY_DEPOSIT=
MIN_WITHDRAWAL=10
MAX_WITHDRAWAL=5000
DAILY_WITHDRAWAL=

# Wallet
WALLET_PORT=8081
DATABASE_URL=postgres://wallet:wallet@localhost:5433/wallet?sslmode=disable
REDIS_ADDR=localhost:6379
NATS_URL=nats://localhost:4222

# xcash (self-hosted deposit gateway)
XCASH_BASE_URL=http://localhost:6688
XCASH_APPID=
XCASH_HMAC_KEY=
XCASH_WEBHOOK_SECRET=

# Postgres (used by Docker Compose)
POSTGRES_USER=wallet
POSTGRES_PASSWORD=wallet
POSTGRES_DB=wallet

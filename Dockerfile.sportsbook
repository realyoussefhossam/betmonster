FROM golang:1.26-alpine AS builder

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 go build -o bin/sportsbook-service ./cmd/sportsbook

FROM alpine:3.21

RUN apk add --no-cache ca-certificates

WORKDIR /app
COPY --from=builder /app/bin/sportsbook-service ./sportsbook-service
COPY --from=builder /app/internal/sportsbook/migrations ./internal/sportsbook/migrations

EXPOSE 8083 50053
ENTRYPOINT ["./sportsbook-service"]
